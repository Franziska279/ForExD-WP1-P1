######################################
# FILE NAMES (Stored Separately for Modularity)
######################################
REGION_SHAPE_FILE='S_USA.AdministrativeRegion.shp'

# Sentinel-1 & IDS Files (Use {region_id} for dynamic replacement)
IDS_FILTERED_FILE='region_{region_id}_dca_filtered_ids_usda_polygons.shp'
IDS_SHAPE_FILE='CONUS_Region8_dissolved.shp'
S1DM_SHAPE_FILE='radar_enhanced_forest_disturbance_mapping_region_{region_id}_buffer_{buffer}_s1dm.shp'
S1CD_TILES_BOUNDS_FILE='s1cd_tiles_bounds_region_{region_id}.shp'

# TCC Files (Use {region_id} and {tcc_year} for dynamic replacement)
TCC_INPUT_RASTER = 'nlcd_tcc_conus_{tcc_year}_v2021-4.tif'
TCC_RESAMPLED_RASTER = 'wp1_nlcd_tcc_conus_{tcc_year}_v2021_4_20m.tif'
TCC_EPSG_RASTER = 'wp1_nlcd_tcc_conus_{tcc_year}_v2021_4_20m_EPSG_{crs}.tif'
TCC_CROPPED_RASTER_TEMPLATE = 'wp1_nlcd_tcc_conus_{tcc_year}_v2021_4_20m_EPSG_{crs}_cropped_region_{region_id}.tif'
TCC_NORMALIZED_RASTER_TEMPLATE = 'wp1_nlcd_tcc_conus_{tcc_year}_v2021_4_20m_EPSG_{crs}_cropped_normalized_region_{region_id}.tif'
TCC_DOWNSAMPLED_TEMP_RASTER_TEMPLATE = 'wp1_nlcd_tcc_conus_{tcc_year}_v2021_4_20m_EPSG_{crs}_cropped_normalized_downsampled_temp_region_{region_id}.nc'
TCC_DOWNSAMPLED_RASTER_TEMPLATE = 'wp1_nlcd_tcc_conus_{tcc_year}_v2021_4_20m_EPSG_{crs}_cropped_normalized_downsampled_region_{region_id}.nc'


# EQUI7 Grid Files (Use {resolution}, {pixel_size}, {region_id} and {buffer} for dynamic replacement)
EQUI7_GRID = 'grid_equi7_{resolution}_{pixel_size}_region_{region_id}_buffer_{buffer}.shp'
CONVEX_HULL = 'convex_hulls_{resolution}_{pixel_size}_region_{region_id}_buffer_{buffer}.shp'
INTERSECTED_GRIDS = 'intersected_equi7_grid_{resolution}_{pixel_size}_region_{region_id}_buffer_{buffer}.shp'


# Figure File Names (Use {buffer} for dynamic replacement)
FIGURE_STUDY_AREA='p1_f1_refdm_study_area_{region_id}.png'
FIGURE_RADAR_REDUCTION='p1_f2_ids_refdm_radar_reduction_potential_buffer_{buffer}.png'
FIGURE_OVERLAP='p1_f3_overlap_percentage_buffer_{buffer}.png'
FIGURE_YEAR_LAG='p1_f4_year_lag_ids_s1cd_buffer_{buffer}.png'
FIGURE_SIZE_CHANGE='p1_f5_size_position_change_buffer_{buffer}.png'
FIGURE_BOUNDS_TEMPLATE='bounds_epsg_{crs}_region_{region_id}.png'
FIGURE_TCC_BOUNDS_TEMPLATE='tcc_{tcc_year}_bounds_epsg_{crs}_region_{region_id}.png'
FIGURE_TCC_BOUNDS_SHAPE_TEMPLATE='tcc_{tcc_year}_bounds_shape_epsg_{crs}_region_{region_id}.png'
FIGURE_EQUI7 = 'grid_equi7_{resolution}_{pixel_size}_region_{region_id}_buffer_{buffer}.png'
FIGURE_EQUI7_INTERSECTED = 'intersected_equi7_grid_{resolution}_{pixel_size}_region_{region_id}_buffer_{buffer}.png'
FIGURE_EQUI7_INTERSECTED_BATCH = 'intersected_batch_equi7_grid_{resolution}_{pixel_size}_region_{region_id}_buffer_{buffer}.png'

