# DIRECTORY PATHS
######################################
DATA_DIR='/net/projects/forexd/WP1/Data'
SENTINEL2_MINICUBES_DIR="${DATA_DIR}/S2_Cubes/"
SENTINEL2_CUBES_PP_DIR="${DATA_DIR}/S2_Minicubes_IDS_R8_Preprocessed/"
